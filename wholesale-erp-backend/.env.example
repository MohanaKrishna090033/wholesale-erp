NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173
DATABASE_URL="postgresql://postgres:password@localhost:5432/wholesale_erp?schema=public"
JWT_ACCESS_SECRET=super_secret_jwt_access_key_must_be_long_32_chars
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_must_be_long_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=cookie_secret_key_16_chars
COOKIE_DOMAIN=localhost
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
BCRYPT_SALT_ROUNDS=12
